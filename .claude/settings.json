{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{REPO_ROOT}}/.claude/auto-build.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{REPO_ROOT}}/.claude/enforce-docs.sh"
          }
        ]
      }
    ]
  }
}
